{
  "hooks": {
    "PostToolUse": [{
      "matcher": "Edit|Write",
      "hooks": [{"type": "command", "command": "if git diff --name-only | grep -q pnpm-lock.yaml; then echo 'WARN: pnpm-lock.yaml changed - verify no platform-specific bindings'; fi"}]
    }]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm run lint*)",
      "Bash(node_modules/.bin/tsc -p tsconfig.app.json --noEmit*)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_screenshot",
      "Bash(just ci*)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_console_messages",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_network_requests",
      "Bash(just --list*)",
      "Bash(uv run pytest *)",
      "Bash(git check-ignore *)"
    ]
  }
}
