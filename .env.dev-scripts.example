# Firebase Admin SDK — service account JSON downloaded from Firebase Console
# IAM & Admin → Service Accounts → Generate new key
# Save the file OUTSIDE the repo (e.g. ~/.secrets/cqs-firebase-admin.json)
FIREBASE_ADMIN_KEY_PATH=/absolute/path/outside/repo/firebase-admin-key.json

# Firebase Web API Key — found in Firebase Console → Project Settings → General
FIREBASE_API_KEY=

# Your Firebase UID (find it in Firebase Console → Authentication → Users)
DEV_USER_UID=

# Production API base URL (Cloud Run)
API_BASE_URL=https://your-api.a.run.app

# Production web app URL (Firebase Hosting)
APP_BASE_URL=https://your-app.web.app
