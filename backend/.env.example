DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carroquesi
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
ALLOWED_ORIGINS=["${BACKEND_URL}"]
FRONTEND_URL=${BACKEND_URL}

