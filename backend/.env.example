DATABASE_URL=postgresql://postgres:postgres@localhost:5432/carroquesi
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
ALLOWED_ORIGINS=["${FRONTEND_URL}"]
FRONTEND_URL=${FRONTEND_URL}

# local dev only — skips Firebase token validation when X-Dev-User-Id header is present
# NEVER enable in production
# DEV_AUTH_BYPASS=true

# Public base URL this API is reachable at — embedded in generated .shortcut
# files. Set to the deployed Cloud Run URL in production.
API_BASE_URL=http://localhost:8000
