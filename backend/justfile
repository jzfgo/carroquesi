default:
    @just --list

# Install / sync dependencies
install:
    uv sync

# Start dev server with hot-reload
dev:
    uv run fastapi dev --host 0.0.0.0 --port 8000

# Start production server
serve:
    uv run fastapi run --host 0.0.0.0 --port 8000

# Lint (ruff check)
lint:
    uv run ruff check

# Format (ruff format)
format:
    uv run ruff format

# Formatting check (ruff format --check)
format-check:
    uv run ruff format --check

# Run all tests
test:
    uv run pytest

# Run a single test file (usage: just backend test-file tests/path/to/test.py)
test-file file:
    uv run pytest {{file}}

# Add a dependency
add package:
    uv add {{package}}

# Run pending migrations
migrate:
    uv run alembic upgrade head

# Generate a new migration
migration name:
    uv run alembic revision --autogenerate -m "{{name}}"

# Show current migration status
migration-status:
    uv run alembic current

# Roll back one migration
migration-rollback:
    uv run alembic downgrade -1

# Seed the local database with test data
seed:
    uv run python scripts/seed.py

# Grant admin privileges to a user (usage: just backend set-admin <firebase_uid>)
set-admin uid:
    uv run python scripts/set_admin.py {{uid}}

# Manage a feature flag for a user (usage: just backend feature <firebase_uid> <flag> <on|off|reset>)
feature uid flag action:
    uv run python scripts/manage_feature.py {{uid}} {{flag}} {{action}}
