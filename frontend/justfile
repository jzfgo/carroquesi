nvm-dir := env('NVM_DIR', env('HOME') + PATH_SEP + '.nvm')
nvm-exec := nvm-dir + PATH_SEP + 'nvm-exec'

default:
    @just --list

# Install dependencies
install:
    {{nvm-exec}} npm install

# Start dev server
dev:
    {{nvm-exec}} npm run dev -- --host 0.0.0.0

# Production build
build:
    {{nvm-exec}} npm run build

# Preview production build
preview:
    {{nvm-exec}} npm run preview

# Run unit tests
test:
    {{nvm-exec}} npm run test

# Run tests in watch mode
test-watch:
    {{nvm-exec}} npm run test:watch

# Lint
lint:
    {{nvm-exec}} npm run lint

# Type-check (uses tsconfig.app.json — root tsconfig has files:[] and always passes silently)
typecheck:
    {{nvm-exec}} npm run typecheck
