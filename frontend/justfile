nvm-dir := env('NVM_DIR', env('HOME') + PATH_SEP + '.nvm')
nvm-exec := nvm-dir + PATH_SEP + 'nvm-exec'
port := env('FRONTEND_PORT', '5173')

default:
    @just --list

# Install dependencies
install:
    {{ nvm-exec }} pnpm install

# Start dev server with hot-reload (vite)
[arg('scope', pattern='local|network')]
dev scope="local":
    {{ nvm-exec }} pnpm dev {{ if scope == "network" { "--host 0.0.0.0" } else { "--host localhost" } }} --port {{ port }}

# Production build (tsc -b & vite build)
build:
    {{ nvm-exec }} pnpm build

# Preview production build (vite preview)
preview:
    {{ nvm-exec }} pnpm preview

# Run unit tests (vitest run)
test:
    {{ nvm-exec }} pnpm test

# Run tests in watch mode (vitest)
test-watch:
    {{ nvm-exec }} pnpm test:watch

# Run end-to-end tests (playwright test)
test-e2e:
    {{ nvm-exec }} pnpm test:e2e

# Regenerate Playwright visual-regression baselines via Docker (matches CI's Linux font rendering)
update-snapshots:
    #!/usr/bin/env bash
    set -euo pipefail
    version=$({{ nvm-exec }} node -p "require('./package.json').devDependencies['@playwright/test'].match(/\d+\.\d+\.\d+(?:-[a-zA-Z0-9.-]+)?/)[0]")
    docker run --rm \
      -v "$(pwd):/work" \
      -v carroquesi-playwright-node-modules:/work/node_modules \
      -v carroquesi-playwright-pnpm-store:/pnpm-store \
      -w /work \
      "mcr.microsoft.com/playwright:v${version}-noble" \
      bash -c "corepack enable && pnpm --config.store-dir=/pnpm-store install --frozen-lockfile && pnpm exec playwright test --update-snapshots"

# Format (prettier --write ., code + styles)
format:
    {{ nvm-exec }} pnpm format

# Check format (prettier --check ., code + styles)
format-check:
    {{ nvm-exec }} pnpm format:check

# Lint (eslint + stylelint)
lint:
    {{ nvm-exec }} pnpm lint

# Type-check (tsc -p tsconfig.app.json --noEmit)
typecheck:
    {{ nvm-exec }} pnpm typecheck

typecheck-watch:
    {{ nvm-exec }} pnpm typecheck:watch

# Regenerate PWA icons from source assets in public/
pwa-icons:
    {{ nvm-exec }} pnpm generate-pwa-assets

# Deploy to Firebase Hosting
deploy:
    {{ nvm-exec }} pnpm deploy
