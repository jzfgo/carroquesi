default:
    just --list

# Install dependencies
install:
    npm install

# Start dev server
dev:
    npm run dev -- --host 0.0.0.0

# Production build
build:
    npm run build

# Preview production build
preview:
    npm run preview

# Run unit tests
test:
    npm run test

# Run tests in watch mode
test-watch:
    npm run test:watch

# Lint
lint:
    npm run lint

# Type-check (uses tsconfig.app.json — root tsconfig has files:[] and always passes silently)
typecheck:
    npx tsc -p tsconfig.app.json --noEmit
