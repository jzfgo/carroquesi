#!/usr/bin/env bash
# Ensure CHANGELOG.md is up to date before pushing.
# Requires git-cliff: https://git-cliff.org/docs/installation
set -euo pipefail

if ! command -v git-cliff &>/dev/null; then
  echo "⚠️  git-cliff not found — skipping changelog check (install: brew install git-cliff)"
  exit 0
fi

# Only act if there are unreleased commits that would produce visible sections
if ! git cliff --unreleased | grep -q '^### '; then
  exit 0
fi

# Run changelog and check if anything changed
tmp=$(mktemp)
cp CHANGELOG.md "$tmp"
just changelog
if diff -q "$tmp" CHANGELOG.md >/dev/null 2>&1; then
  cp "$tmp" CHANGELOG.md
  rm "$tmp"
  exit 0
fi
rm "$tmp"

echo ""
echo "📋 CHANGELOG.md was updated with unreleased commits. Commit it before pushing:"
echo "   git add CHANGELOG.md && git commit -m 'chore: update changelog'"
echo ""
exit 1
